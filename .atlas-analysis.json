  "keyFeatures": [
    "Page-based storage engine with 4KB pages",
    "SQL parser and executor supporting CREATE, INSERT, SELECT, UPDATE, DELETE, DROP",
    "WHERE clause filtering with comparison and logical operators",
    "Multi-page table support with linked pages",
    "Interactive REPL with meta-commands",
    "Built-in benchmark suite for performance testing",
    "File-based locking mechanism",
    "Support for INTEGER, TEXT, BOOLEAN, and NULL data types"
  ],
  "publicApiSurface": [
    "Repl::new() and Repl::run()",
    "Executor::new() and Executor::execute()",
    "Parser::new() and Parser::parse()",
    "PageManager::new() and page operations",
    "TableCatalog::new() and table operations",
    "Statement enum (CreateTable, Insert, Select, Update, Delete, DropTable)",
    "Meta-commands: .open, .help, .benchmark, .exit"
  ]
